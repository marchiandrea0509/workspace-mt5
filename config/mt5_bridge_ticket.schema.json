{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gray.local/schemas/mt5_bridge_ticket.schema.json",
  "title": "Gray MT5 Paper Bridge Ticket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bridge_version",
    "ticket_id",
    "created_at",
    "mode",
    "symbol",
    "side",
    "order_plan",
    "entries",
    "stop_loss",
    "take_profit"
  ],
  "properties": {
    "bridge_version": {
      "type": "string",
      "const": "mt5.paper.v1"
    },
    "ticket_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": [
        "paper"
      ]
    },
    "symbol": {
      "type": "string",
      "minLength": 1
    },
    "side": {
      "type": "string",
      "enum": [
        "buy",
        "sell"
      ]
    },
    "order_plan": {
      "type": "string",
      "enum": [
        "market",
        "limit_ladder",
        "stop_entry",
        "hybrid_ladder_breakout"
      ]
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "client_entry_id",
          "entry_type",
          "volume_lots"
        ],
        "properties": {
          "client_entry_id": {
            "type": "string",
            "minLength": 1
          },
          "entry_type": {
            "type": "string",
            "enum": [
              "market",
              "limit",
              "stop"
            ]
          },
          "price": {
            "type": [
              "number",
              "null"
            ]
          },
          "volume_lots": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "comment": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "entry_type": {
                  "const": "market"
                }
              }
            },
            "then": {
              "properties": {
                "price": {
                  "type": "null"
                }
              }
            },
            "else": {
              "required": [
                "price"
              ]
            }
          }
        ]
      }
    },
    "stop_loss": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "price"
      ],
      "properties": {
        "price": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "take_profit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "price"
      ],
      "properties": {
        "price": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "trailing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "trigger_price": {
          "type": [
            "number",
            "null"
          ]
        },
        "activation_price": {
          "type": [
            "number",
            "null"
          ]
        },
        "distance_mode": {
          "type": "string",
          "enum": [
            "price",
            "percent",
            "atr"
          ]
        },
        "distance_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "distance_price": {
          "type": [
            "number",
            "null"
          ]
        },
        "step_price": {
          "type": [
            "number",
            "null"
          ]
        },
        "atr_period": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "atr_timeframe": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "M1",
            "M5",
            "M15",
            "M30",
            "H1",
            "H4",
            "D1",
            "W1",
            "MN1",
            null
          ]
        }
      }
    },
    "max_risk_usdt": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "strategy_context": {
      "type": "object"
    },
    "note": {
      "type": "string"
    }
  }
}
